# =============================================================================
# AIRIS Frontend — Development Environment Template
# =============================================================================
# Copy to .env.local for local development.
# The Next.js dev server proxies /api/v1/* to the backend on port 8000,
# so the browser never makes cross-origin requests in development.
# =============================================================================

# Next.js proxy rewrites /api/v1/* → http://127.0.0.1:8000/api/v1/*
NEXT_PUBLIC_API_BASE_URL=/api/v1

# SSR fetch target (same as proxy destination, used server-side)
NEXT_PUBLIC_API_BACKEND_URL=http://127.0.0.1:8000/api/v1

# Backend base for the Next.js rewrite rule in next.config.ts
API_BACKEND_URL=http://127.0.0.1:8000

# WebSocket — point directly at the backend; proxy can't upgrade to ws
# NEXT_PUBLIC_WS_API_BASE_URL=ws://127.0.0.1:8000/api/v1

# Candidate management module (enable when backend routes are deployed)
NEXT_PUBLIC_USE_CANDIDATE_MANAGEMENT=false
