# =============================================================================
# AIRIS Frontend — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local (it is gitignored). Only .env.example is committed.
#
# Next.js rule: variables prefixed NEXT_PUBLIC_ are embedded in the browser
# bundle at build time.  Variables WITHOUT that prefix are server-only (SSR /
# route handlers / next.config.ts) and are never exposed to the client.
# =============================================================================

# -----------------------------------------------------------------------------
# API Connectivity
# -----------------------------------------------------------------------------

# Browser-side REST base URL.
# Development (recommended): use the Next.js proxy so the browser never crosses
# origins and you avoid CORS configuration entirely.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Backend base URL used by the Next.js rewrite proxy (next.config.ts) and
# SSR fetch calls.  The browser never sees this value directly.
# Development default: http://127.0.0.1:8000
API_BACKEND_URL=http://127.0.0.1:8000

# Explicit SSR override (used in server components when NEXT_PUBLIC_API_BASE_URL
# is a relative path that cannot be resolved server-side).
# Usually equals API_BACKEND_URL + /api/v1.
NEXT_PUBLIC_API_BACKEND_URL=http://127.0.0.1:8000/api/v1

# WebSocket base URL for real-time features (LiveKit, interview copilot).
# Defaults to the REST base URL with http→ws scheme substitution.
# Override explicitly in production/staging where the WS server differs.
# Example: wss://api.yourdomain.com/api/v1
# NEXT_PUBLIC_WS_API_BASE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable the candidate-management module (set true only when the backend
# candidate-management routes are deployed and configured).
NEXT_PUBLIC_USE_CANDIDATE_MANAGEMENT=false
