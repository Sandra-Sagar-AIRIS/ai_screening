# Recommended for local dev (proxied via Next.js — no CORS issues):
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_API_BACKEND_URL=http://127.0.0.1:8000/api/v1

# Or talk to the backend directly (requires CORS_ORIGINS on the API):
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

NEXT_PUBLIC_USE_CANDIDATE_MANAGEMENT=false
