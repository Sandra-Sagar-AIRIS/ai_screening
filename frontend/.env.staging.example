# =============================================================================
# AIRIS Frontend — Staging Environment Template
# =============================================================================
# Inject as environment variables in your CI/CD platform (Vercel, Railway, etc.)
# or copy to .env.local if running the staging build locally.
# =============================================================================

# Staging API (direct — no local proxy in staging/production builds)
NEXT_PUBLIC_API_BASE_URL=https://api-staging.yourdomain.com/api/v1
NEXT_PUBLIC_API_BACKEND_URL=https://api-staging.yourdomain.com/api/v1
API_BACKEND_URL=https://api-staging.yourdomain.com

# WebSocket for LiveKit / real-time features
NEXT_PUBLIC_WS_API_BASE_URL=wss://api-staging.yourdomain.com/api/v1

# Enable candidate management if backend is deployed on staging
NEXT_PUBLIC_USE_CANDIDATE_MANAGEMENT=false
