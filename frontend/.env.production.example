# =============================================================================
# AIRIS Frontend — Production Environment Template
# =============================================================================
# Inject as environment variables in your deployment platform.
# NEVER commit .env.local or .env.production.local to source control.
# =============================================================================

# Production API (direct — no Next.js proxy in production builds)
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_BACKEND_URL=https://api.yourdomain.com/api/v1
API_BACKEND_URL=https://api.yourdomain.com

# WebSocket for LiveKit / real-time features
NEXT_PUBLIC_WS_API_BASE_URL=wss://api.yourdomain.com/api/v1

# Enable candidate management module in production
NEXT_PUBLIC_USE_CANDIDATE_MANAGEMENT=false
