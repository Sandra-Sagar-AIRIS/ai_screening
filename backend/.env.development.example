# =============================================================================
# AIRIS Backend — Development Environment Template
# =============================================================================
# Copy to .env for local development.
# All external services use free-tier or sandbox credentials.
# Secrets shown here are illustrative — replace with your own values.
# =============================================================================

APP_NAME=AIRIS Backend
APP_ENV=development
DEBUG=true

# PostgreSQL / Supabase — local Supabase dev project or Docker Postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/airis_dev

SUPABASE_URL=https://<local-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-local-service-role-key>
SUPABASE_STORAGE_BUCKET=resumes

# JWT — any random value is acceptable in local dev; startup will warn if using default
JWT_SECRET_KEY=dev-only-change-me-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=120
JWT_REFRESH_TOKEN_EXP_DAYS=30
JWT_MAX_CONCURRENT_SESSIONS_DEFAULT=10

# CORS — localhost origins for Next.js dev server
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
FRONTEND_URL=http://localhost:3000

# SMTP — Brevo sandbox (or leave blank to skip email in dev)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dev@yourdomain.com

# OpenAI — required for AI screening tests; use a low-quota key
OPENAI_API_KEY=sk-...
# OPENAI_SCREENING_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_SECONDS=60

# Groq — JD parsing + ATS enrichment
GROQ_API_KEY=gsk_...
GROQ_API_KEY_ATS=gsk_...
# GROQ_ATS_MODEL=llama-3.3-70b-versatile

# xAI Grok — optional; keep false to skip extra latency
# GROK_API_KEY=xai-...
RESUME_GROK_INTELLIGENCE=false

# AssemblyAI — real-time transcription (optional in dev; leave blank to disable)
ASSEMBLYAI_API_KEY=

# LiveKit — use LiveKit Cloud free tier or local livekit-server
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_WS_URL=ws://localhost:7880

# Copilot
COPILOT_ENABLED=true
COPILOT_MODEL=gpt-4.1-mini

# Twilio — leave blank to disable WhatsApp in dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/candidate-management/communication/oauth/callback

# Microsoft OAuth
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:8000/api/v1/candidate-management/communication/oauth/callback
MS_TENANT_ID=common

# Comm encryption — generate: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
COMM_TOKEN_ENCRYPTION_KEY=
COMM_OAUTH_STATE_SECRET=

# Celery — disabled by default in local dev
CELERY_DISPATCH_ENABLED=false
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Permission cache
PERMISSION_CACHE_ENABLED=true
PERMISSION_CACHE_TTL_SECONDS=60
