APP_NAME=AIRIS Backend
APP_ENV=development
DEBUG=false

# Supabase/PostgreSQL connection string.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres:password@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Supabase Storage (resume uploads)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# SUPABASE_STORAGE_BUCKET=resumes

# Optional: set if you want reflection/autogenerate scoped to one schema
# DB_SCHEMA=public
DB_SCHEMA=

# xAI Grok — hybrid ATS semantic enrichment (optional; deterministic ATS works without it).
# GROK_API_KEY=
# GROK_API_BASE=https://api.x.ai/v1
# GROK_MODEL=grok-2-latest
# GROK_TIMEOUT_SECONDS=45
# Optional: run structured Grok resume enrichment after local extraction (adds latency on parse).
# RESUME_GROK_INTELLIGENCE=false

# Invite emails (Brevo SMTP). SMTP_FROM must match a verified sender in Brevo.
# FRONTEND_URL=http://localhost:3000
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-brevo-login-email
# SMTP_PASSWORD=your-brevo-smtp-key
# SMTP_FROM=noreply@yourdomain.com

# Communication Hub OAuth integrations (Phase 1A)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/candidate-management/communication/oauth/callback
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=http://localhost:8000/api/v1/candidate-management/communication/oauth/callback
# MS_TENANT_ID=common
# COMM_TOKEN_ENCRYPTION_KEY=
# COMM_OAUTH_STATE_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Background ATS tasks (requires Redis). Leave false in local dev to avoid broker timeouts.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_DISPATCH_ENABLED=false

# Cache role permissions in-process (seconds). Reduces DB load on every API call.
PERMISSION_CACHE_ENABLED=true
PERMISSION_CACHE_TTL_SECONDS=60

