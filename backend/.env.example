# =============================================================================
# AIRIS Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env (it is gitignored). Only .env.example is committed.
#
# Generate a secure random value for any secret field with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

APP_NAME=AIRIS Backend
# Options: development | staging | production
APP_ENV=development
# Set true only in local development (enables detailed error traces)
DEBUG=false
# API documentation visibility (/docs, /redoc, /openapi.json).
# Omit or leave blank to use the default: enabled in development/staging,
# DISABLED in production.  Set true to force-enable in production (internal use).
# DOCS_ENABLED=

# -----------------------------------------------------------------------------
# Database — PostgreSQL / Supabase
# -----------------------------------------------------------------------------
# Full SQLAlchemy-compatible PostgreSQL connection string. Required.
# Supabase format: postgresql://postgres.<project-ref>:<password>@<host>:5432/postgres
# Note: psycopg v3 (postgresql+psycopg://) is applied automatically if omitted.
DATABASE_URL=

# Supabase project REST API URL (used for storage client, not DB access)
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service role key for Storage operations (resume uploads)
# Obtain from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket name for uploaded resumes
SUPABASE_STORAGE_BUCKET=resumes

# Optional: restrict schema reflection to one schema (default: public)
DB_SCHEMA=

# -----------------------------------------------------------------------------
# Authentication & JWT
# -----------------------------------------------------------------------------
# REQUIRED — minimum 32 characters, cryptographically random.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: using the default value will cause startup failure in production/staging.
JWT_SECRET_KEY=

JWT_ALGORITHM=HS256
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXP_MINUTES=60
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXP_DAYS=7
# Max concurrent sessions per user
JWT_MAX_CONCURRENT_SESSIONS_DEFAULT=5

# -----------------------------------------------------------------------------
# CORS & Frontend URL
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slashes).
# Production example: https://app.yourdomain.com,https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base URL for invite emails and OAuth redirects (no trailing slash).
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email — Brevo SMTP
# -----------------------------------------------------------------------------
# Brevo (formerly Sendinblue): https://app.brevo.com/settings/keys/smtp
# SMTP_FROM must match a verified sender domain in Brevo.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# AI Services — OpenAI
# -----------------------------------------------------------------------------
# OpenAI API key for AI Screening (GPT-4.1-mini).
# Obtain from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Override the model used for AI screening (default: gpt-4.1-mini)
# OPENAI_SCREENING_MODEL=gpt-4.1-mini

# Timeout for OpenAI API calls in seconds
# OPENAI_TIMEOUT_SECONDS=60

# -----------------------------------------------------------------------------
# AI Services — Groq
# -----------------------------------------------------------------------------
# Groq API key for AI-powered job description parsing.
# Obtain from: https://console.groq.com/keys
GROQ_API_KEY=

# Separate Groq key for ATS semantic enrichment (can reuse GROQ_API_KEY)
GROQ_API_KEY_ATS=

# Groq model for ATS (default: llama-3.3-70b-versatile)
# GROQ_ATS_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# AI Services — xAI Grok (optional)
# -----------------------------------------------------------------------------
# xAI API key for hybrid ATS resume enrichment (optional).
# Obtain from: https://console.x.ai/
# GROK_API_KEY=
# GROK_MODEL=grok-3-mini
# Enable Grok resume intelligence pass after local extraction (adds latency)
RESUME_GROK_INTELLIGENCE=false

# -----------------------------------------------------------------------------
# AI Services — AssemblyAI (Interview Transcription)
# -----------------------------------------------------------------------------
# AssemblyAI API key for real-time interview transcription.
# Obtain from: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=

# Transcription provider for the /copilot/transcribe-audio batch endpoint.
# "whisper"  (default) — OpenAI Whisper; requires OPENAI_API_KEY.
# The live realtime pipeline always uses AssemblyAI directly from the browser
# regardless of this setting.
# TRANSCRIPTION_PROVIDER=whisper

# -----------------------------------------------------------------------------
# Video Conferencing — LiveKit
# -----------------------------------------------------------------------------
# LiveKit Cloud: https://cloud.livekit.io (free tier available)
# Self-hosted: set LIVEKIT_WS_URL to wss://your-server
# Obtain API credentials from LiveKit Cloud dashboard.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# WebSocket URL for the LiveKit server
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# -----------------------------------------------------------------------------
# AI Interview Copilot
# -----------------------------------------------------------------------------
COPILOT_ENABLED=true
# Model used for interview copilot real-time suggestions
COPILOT_MODEL=gpt-4.1-mini

# -----------------------------------------------------------------------------
# Communications — Twilio (WhatsApp)
# -----------------------------------------------------------------------------
# Twilio credentials for WhatsApp messaging.
# Obtain from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp sender number (must be approved in Twilio console)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# -----------------------------------------------------------------------------
# Communication Hub — OAuth (Google & Microsoft)
# -----------------------------------------------------------------------------
# Google OAuth for Gmail integration.
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/candidate-management/communication/oauth/callback

# Microsoft OAuth for Outlook integration.
# Create app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=http://localhost:8000/api/v1/candidate-management/communication/oauth/callback
# Use 'common' for multi-tenant, or your specific tenant ID
MS_TENANT_ID=common

# Encryption key for stored OAuth tokens — 32 bytes base64-encoded.
# Generate: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
COMM_TOKEN_ENCRYPTION_KEY=
# Random secret for OAuth state parameter validation (prevents CSRF)
COMM_OAUTH_STATE_SECRET=

# -----------------------------------------------------------------------------
# Background Tasks — Celery / Redis (optional)
# -----------------------------------------------------------------------------
# Required only if CELERY_DISPATCH_ENABLED=true (enables async ATS rescoring).
# Leave false in local dev to avoid broker timeouts.
CELERY_DISPATCH_ENABLED=false
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# Permission Cache
# -----------------------------------------------------------------------------
# In-process permission cache — reduces DB load on every authenticated API call.
PERMISSION_CACHE_ENABLED=true
# Cache TTL in seconds (0 to disable)
PERMISSION_CACHE_TTL_SECONDS=60

# -----------------------------------------------------------------------------
# AWS (Future use — currently not used)
# -----------------------------------------------------------------------------
# AIRIS currently uses Supabase Storage rather than AWS S3.
# If AWS services are introduced, credentials MUST be provided via IAM roles
# (instance profile / task role / OIDC) — never hardcoded access keys.
# Fallback environment variables below are for LOCAL DEVELOPMENT ONLY:
#
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
#
# Production deployment MUST use IAM roles:
#   - ECS: task role with required IAM policies
#   - EC2: instance profile
#   - Lambda: execution role
#   - GitHub Actions: OIDC federation (no long-lived keys)
