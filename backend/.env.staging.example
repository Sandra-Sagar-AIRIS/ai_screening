# =============================================================================
# AIRIS Backend — Staging Environment Template
# =============================================================================
# Copy to .env (or inject as environment variables in your CI/CD platform).
# Staging mirrors production configuration but uses isolated data & credentials.
# All secrets MUST be managed via your secrets manager (Doppler, AWS SSM, etc.).
# =============================================================================

APP_NAME=AIRIS Backend
APP_ENV=staging
DEBUG=false

# PostgreSQL / Supabase — staging project (separate from production)
DATABASE_URL=postgresql+psycopg://postgres.<staging-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://<staging-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>
SUPABASE_STORAGE_BUCKET=resumes-staging

# JWT — REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-secure-random-value>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=60
JWT_REFRESH_TOKEN_EXP_DAYS=7
JWT_MAX_CONCURRENT_SESSIONS_DEFAULT=5

# CORS — staging domain only
CORS_ORIGINS=https://staging.yourdomain.com
FRONTEND_URL=https://staging.yourdomain.com

# SMTP — Brevo staging sender (use a staging/test sender domain)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<brevo-smtp-login>
SMTP_PASSWORD=<brevo-smtp-key>
SMTP_FROM=noreply@staging.yourdomain.com

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_SCREENING_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_SECONDS=60

# Groq
GROQ_API_KEY=gsk_...
GROQ_API_KEY_ATS=gsk_...

# xAI Grok (optional)
# GROK_API_KEY=xai-...
RESUME_GROK_INTELLIGENCE=false

# AssemblyAI
ASSEMBLYAI_API_KEY=<assemblyai-key>

# LiveKit — staging LiveKit Cloud project
LIVEKIT_API_KEY=<staging-lk-api-key>
LIVEKIT_API_SECRET=<staging-lk-api-secret>
LIVEKIT_WS_URL=wss://<staging-project>.livekit.cloud

# Copilot
COPILOT_ENABLED=true
COPILOT_MODEL=gpt-4.1-mini

# Twilio — staging sandbox number
TWILIO_ACCOUNT_SID=<staging-account-sid>
TWILIO_AUTH_TOKEN=<staging-auth-token>
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Google OAuth — staging OAuth app
GOOGLE_CLIENT_ID=<staging-google-client-id>
GOOGLE_CLIENT_SECRET=<staging-google-client-secret>
GOOGLE_REDIRECT_URI=https://staging.yourdomain.com/api/v1/candidate-management/communication/oauth/callback

# Microsoft OAuth — staging app registration
MS_CLIENT_ID=<staging-ms-client-id>
MS_CLIENT_SECRET=<staging-ms-client-secret>
MS_REDIRECT_URI=https://staging.yourdomain.com/api/v1/candidate-management/communication/oauth/callback
MS_TENANT_ID=common

# Comm encryption — REQUIRED: generate distinct value from production
COMM_TOKEN_ENCRYPTION_KEY=<base64-32-byte-random>
COMM_OAUTH_STATE_SECRET=<random-hex-32>

# Celery / Redis — enable for staging load testing
CELERY_DISPATCH_ENABLED=true
CELERY_BROKER_URL=redis://<redis-host>:6379/0
CELERY_RESULT_BACKEND=redis://<redis-host>:6379/1

# Permission cache
PERMISSION_CACHE_ENABLED=true
PERMISSION_CACHE_TTL_SECONDS=60
