# =============================================================================
# AIRIS Backend — Production Environment Template
# =============================================================================
# DO NOT store real secrets in this file.
# All values must be injected at runtime via your secrets manager
# (Doppler, AWS SSM Parameter Store, or platform environment variables).
#
# ⚠  JWT_SECRET_KEY is REQUIRED in production — startup will fail without it.
# ⚠  COMM_TOKEN_ENCRYPTION_KEY is REQUIRED — losing it means OAuth tokens
#    stored in the database become unreadable; rotate carefully (see INFRA.md).
# =============================================================================

APP_NAME=AIRIS Backend
APP_ENV=production
DEBUG=false
# Docs are DISABLED by default in production (APP_ENV=production).
# Uncomment and set true only for intentional internal access.
# DOCS_ENABLED=false

# PostgreSQL / Supabase — production project, transaction-mode pooler (port 6543)
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<production-service-role-key>
SUPABASE_STORAGE_BUCKET=resumes

# JWT — REQUIRED; MUST be cryptographically random (≥ 32 bytes)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<generate-a-secure-random-value>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXP_MINUTES=60
JWT_REFRESH_TOKEN_EXP_DAYS=7
JWT_MAX_CONCURRENT_SESSIONS_DEFAULT=5

# CORS — production domain(s) only; no localhost
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com
FRONTEND_URL=https://app.yourdomain.com

# SMTP — Brevo production sender (verified sender domain required)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<brevo-smtp-login>
SMTP_PASSWORD=<brevo-smtp-key>
SMTP_FROM=noreply@yourdomain.com

# OpenAI — production quota key
OPENAI_API_KEY=sk-...
# OPENAI_SCREENING_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_SECONDS=60

# Groq
GROQ_API_KEY=gsk_...
GROQ_API_KEY_ATS=gsk_...
# GROQ_ATS_MODEL=llama-3.3-70b-versatile

# xAI Grok (optional — adds latency if RESUME_GROK_INTELLIGENCE=true)
# GROK_API_KEY=xai-...
RESUME_GROK_INTELLIGENCE=false

# AssemblyAI
ASSEMBLYAI_API_KEY=<assemblyai-key>

# LiveKit — production LiveKit Cloud project
LIVEKIT_API_KEY=<prod-lk-api-key>
LIVEKIT_API_SECRET=<prod-lk-api-secret>
LIVEKIT_WS_URL=wss://<prod-project>.livekit.cloud

# Copilot
COPILOT_ENABLED=true
COPILOT_MODEL=gpt-4.1-mini

# Twilio — production approved sender
TWILIO_ACCOUNT_SID=<prod-account-sid>
TWILIO_AUTH_TOKEN=<prod-auth-token>
TWILIO_WHATSAPP_NUMBER=whatsapp:+<approved-number>

# Google OAuth — production OAuth app
GOOGLE_CLIENT_ID=<prod-google-client-id>
GOOGLE_CLIENT_SECRET=<prod-google-client-secret>
GOOGLE_REDIRECT_URI=https://app.yourdomain.com/api/v1/candidate-management/communication/oauth/callback

# Microsoft OAuth — production app registration
MS_CLIENT_ID=<prod-ms-client-id>
MS_CLIENT_SECRET=<prod-ms-client-secret>
MS_REDIRECT_URI=https://app.yourdomain.com/api/v1/candidate-management/communication/oauth/callback
MS_TENANT_ID=common

# Comm encryption — REQUIRED; rotate only with a migration plan (see INFRA.md)
# Generate: python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
COMM_TOKEN_ENCRYPTION_KEY=<base64-32-byte-random>
COMM_OAUTH_STATE_SECRET=<random-hex-32>

# Celery / Redis — enable in production
CELERY_DISPATCH_ENABLED=true
CELERY_BROKER_URL=redis://<redis-host>:6379/0
CELERY_RESULT_BACKEND=redis://<redis-host>:6379/1

# Permission cache
PERMISSION_CACHE_ENABLED=true
PERMISSION_CACHE_TTL_SECONDS=60

# AWS — NOT currently used (Supabase Storage is the active file store).
# If AWS services are introduced, use IAM roles (task role / instance profile /
# OIDC federation) — NEVER hardcode access keys in production.
# AWS_DEFAULT_REGION=ap-southeast-1
